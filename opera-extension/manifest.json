{
    "manifest_version": 3,
    "name": "LL Integration",
    "version": "0.8.0",
    "description": "Bridge LoversLab and external archive downloads into Mod Organizer 2 and Vortex.",
    "key": "",
    "icons": {
        "16": "icons/ll_integration_16.png",
        "32": "icons/ll_integration_32.png",
        "48": "icons/ll_integration_48.png",
        "96": "icons/ll_integration_96.png",
        "128": "icons/ll_integration_128.png"
    },
    "permissions": [
        "cookies",
        "downloads",
        "nativeMessaging",
        "activeTab",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "https://www.loverslab.com/*",
        "https://loverslab.com/*",
        "https://dwemermods.com/*",
        "https://www.dwemermods.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.loverslab.com/*",
                "https://loverslab.com/*",
                "https://dwemermods.com/*",
                "https://www.dwemermods.com/*"
            ],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_title": "LL Integration",
        "default_icon": {
            "16": "icons/ll_integration_16.png",
            "32": "icons/ll_integration_32.png"
        },
        "default_popup": "popup.html"
    }
}
